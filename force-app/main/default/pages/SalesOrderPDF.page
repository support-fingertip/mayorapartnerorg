<apex:page standardController="Sales_Order__c" extensions="SalesOrderPDFController" renderAs="pdf" applyHtmlTag="false" showHeader="false" sidebar="false">
<html>
<head>
<style type="text/css">
    @page {
        size: A4;
        margin: 15mm;
    }
    body {
        font-family: Arial, Helvetica, sans-serif;
        font-size: 11px;
        color: #333;
    }
    .header {
        border-bottom: 2px solid #2c3e50;
        padding-bottom: 10px;
        margin-bottom: 15px;
    }
    .company-name {
        font-size: 20px;
        font-weight: bold;
        color: #2c3e50;
    }
    .order-title {
        font-size: 16px;
        color: #e74c3c;
        text-align: right;
    }
    .status-badge {
        display: inline-block;
        padding: 2px 8px;
        border-radius: 3px;
        font-size: 10px;
        font-weight: bold;
        color: white;
        background-color: #2c3e50;
    }
    .info-table {
        width: 100%;
        margin-bottom: 15px;
    }
    .info-table td {
        vertical-align: top;
        padding: 3px;
    }
    .label {
        font-weight: bold;
        color: #555;
        width: 120px;
    }
    .items-table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 15px;
    }
    .items-table th {
        background-color: #2c3e50;
        color: white;
        padding: 8px 5px;
        text-align: left;
        font-size: 10px;
    }
    .items-table td {
        padding: 6px 5px;
        border-bottom: 1px solid #ddd;
        font-size: 10px;
    }
    .items-table tr:nth-child(even) {
        background-color: #f9f9f9;
    }
    .totals-section {
        float: right;
        width: 300px;
        margin-top: 15px;
    }
    .totals-table {
        width: 100%;
        border-collapse: collapse;
    }
    .totals-table td {
        padding: 5px;
        border-bottom: 1px solid #eee;
    }
    .totals-table .grand-total {
        font-size: 14px;
        font-weight: bold;
        color: #2c3e50;
        border-top: 2px solid #2c3e50;
    }
    .footer {
        position: fixed;
        bottom: 0;
        width: 100%;
        text-align: center;
        font-size: 9px;
        color: #999;
        border-top: 1px solid #ddd;
        padding-top: 5px;
    }
    .bill-to, .ship-to {
        width: 48%;
        display: inline-block;
        vertical-align: top;
    }
    .section-title {
        font-weight: bold;
        color: #2c3e50;
        font-size: 12px;
        margin-bottom: 5px;
        border-bottom: 1px solid #2c3e50;
        padding-bottom: 3px;
    }
    .sku-code {
        font-size: 9px;
        color: #777;
    }
</style>
</head>
<body>
    <div class="header">
        <table width="100%">
            <tr>
                <td width="60%">
                    <div class="company-name">{!salesOrder.Account__r.Name}</div>
                    <div>Sales Order</div>
                </td>
                <td width="40%" style="text-align: right;">
                    <div class="order-title">SALES ORDER</div>
                    <div><strong>Order #:</strong> {!salesOrder.Name}</div>
                    <div><strong>Order Date:</strong>
                        <apex:outputText value="{0,date,dd-MMM-yyyy}">
                            <apex:param value="{!salesOrder.Order_Date__c}"/>
                        </apex:outputText>
                    </div>
                    <div><strong>Delivery Date:</strong>
                        <apex:outputText value="{0,date,dd-MMM-yyyy}">
                            <apex:param value="{!salesOrder.Delivery_Date__c}"/>
                        </apex:outputText>
                    </div>
                    <div style="margin-top: 5px;">
                        <span class="status-badge">{!salesOrder.Status__c}</span>
                    </div>
                </td>
            </tr>
        </table>
    </div>

    <div>
        <div class="bill-to">
            <div class="section-title">Bill To</div>
            <div><strong>{!salesOrder.Account__r.Name}</strong></div>
            <div>{!salesOrder.Account__r.BillingStreet}</div>
            <div>{!salesOrder.Account__r.BillingCity}, {!salesOrder.Account__r.BillingState} {!salesOrder.Account__r.BillingPostalCode}</div>
            <div>GSTIN: {!salesOrder.Account__r.GSTIN__c}</div>
            <apex:outputPanel rendered="{!NOT(ISBLANK(salesOrder.Account__r.Phone))}">
                <div>Phone: {!salesOrder.Account__r.Phone}</div>
            </apex:outputPanel>
        </div>
        <div class="ship-to">
            <div class="section-title">Ship To</div>
            <div><strong>{!salesOrder.Account__r.Name}</strong></div>
            <div>{!salesOrder.Account__r.ShippingStreet}</div>
            <div>{!salesOrder.Account__r.ShippingCity}, {!salesOrder.Account__r.ShippingState} {!salesOrder.Account__r.ShippingPostalCode}</div>
        </div>
    </div>

    <table class="info-table" style="margin-top: 15px;">
        <tr>
            <td class="label">Territory:</td>
            <td>{!salesOrder.Territory__r.Name}</td>
            <td class="label">Warehouse:</td>
            <td>{!salesOrder.Warehouse__r.Name}</td>
        </tr>
        <tr>
            <td class="label">Trade Channel:</td>
            <td>{!salesOrder.Trade_Channel__c}</td>
            <td class="label">Payment Terms:</td>
            <td>{!salesOrder.Payment_Terms__c}</td>
        </tr>
    </table>

    <table class="items-table">
        <thead>
            <tr>
                <th style="width:4%">#</th>
                <th style="width:22%">Product</th>
                <th style="width:8%">HSN/SAC</th>
                <th style="width:6%">Qty</th>
                <th style="width:6%">Free Qty</th>
                <th style="width:6%">UOM</th>
                <th style="width:10%">Unit Price</th>
                <th style="width:10%">Discount</th>
                <th style="width:10%">Tax</th>
                <th style="width:10%">Total</th>
            </tr>
        </thead>
        <tbody>
            <apex:repeat value="{!lineItems}" var="item">
                <tr>
                    <td>{!item.index}</td>
                    <td>
                        {!item.line.Product_Ext__r.Name}
                        <apex:outputPanel rendered="{!NOT(ISBLANK(item.line.Product_Ext__r.SKU_Code__c))}">
                            <br/><span class="sku-code">{!item.line.Product_Ext__r.SKU_Code__c}</span>
                        </apex:outputPanel>
                    </td>
                    <td>{!item.line.HSN_SAC_Code__c}</td>
                    <td style="text-align:right;">{!item.line.Quantity__c}</td>
                    <td style="text-align:right;">{!item.line.Free_Quantity__c}</td>
                    <td>{!item.line.UOM__c}</td>
                    <td style="text-align:right;">
                        <apex:outputText value="{0, number, ###,##0.00}">
                            <apex:param value="{!item.line.Unit_Price__c}"/>
                        </apex:outputText>
                    </td>
                    <td style="text-align:right;">
                        <apex:outputText value="{0, number, ###,##0.00}">
                            <apex:param value="{!item.line.Discount_Amount__c}"/>
                        </apex:outputText>
                    </td>
                    <td style="text-align:right;">
                        <apex:outputText value="{0, number, ###,##0.00}">
                            <apex:param value="{!item.line.Tax_Amount__c}"/>
                        </apex:outputText>
                    </td>
                    <td style="text-align:right;">
                        <apex:outputText value="{0, number, ###,##0.00}">
                            <apex:param value="{!item.line.Total_Amount__c}"/>
                        </apex:outputText>
                    </td>
                </tr>
            </apex:repeat>
        </tbody>
    </table>

    <div class="totals-section">
        <table class="totals-table">
            <tr>
                <td>Gross Amount:</td>
                <td style="text-align:right;">
                    <apex:outputText value="{0, number, ###,##0.00}">
                        <apex:param value="{!salesOrder.Total_Gross_Amount__c}"/>
                    </apex:outputText>
                </td>
            </tr>
            <tr>
                <td>Discount:</td>
                <td style="text-align:right;">
                    <apex:outputText value="{0, number, ###,##0.00}">
                        <apex:param value="{!salesOrder.Total_Discount__c}"/>
                    </apex:outputText>
                </td>
            </tr>
            <tr>
                <td>Tax:</td>
                <td style="text-align:right;">
                    <apex:outputText value="{0, number, ###,##0.00}">
                        <apex:param value="{!salesOrder.Total_Tax__c}"/>
                    </apex:outputText>
                </td>
            </tr>
            <tr>
                <td class="grand-total">Net Amount (Grand Total):</td>
                <td class="grand-total" style="text-align:right;">
                    <apex:outputText value="{0, number, ###,##0.00}">
                        <apex:param value="{!salesOrder.Total_Net_Amount__c}"/>
                    </apex:outputText>
                </td>
            </tr>
        </table>
    </div>

    <div style="clear:both; margin-top: 50px;">
        <div class="section-title">Amount in Words</div>
        <div>{!amountInWords}</div>
    </div>

    <apex:outputPanel rendered="{!NOT(ISBLANK(salesOrder.Notes__c))}">
        <div style="margin-top: 15px;">
            <div class="section-title">Remarks / Notes</div>
            <div>{!salesOrder.Notes__c}</div>
        </div>
    </apex:outputPanel>

    <div style="margin-top: 30px;">
        <table width="100%">
            <tr>
                <td width="50%">
                </td>
                <td width="50%" style="text-align:right;">
                    <div style="margin-top: 40px; border-top: 1px solid #333; display: inline-block; padding-top: 5px;">
                        Authorized Signatory
                    </div>
                </td>
            </tr>
        </table>
    </div>

    <div class="footer">
        This is a computer-generated document and does not require a physical signature.
    </div>
</body>
</html>
</apex:page>