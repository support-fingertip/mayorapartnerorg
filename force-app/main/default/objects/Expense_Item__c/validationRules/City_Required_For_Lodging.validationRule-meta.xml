<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>City_Required_For_Lodging</fullName>
    <active>true</active>
    <description>City is required when expense type is Lodging.</description>
    <errorConditionFormula>AND(
    ISPICKVAL(Expense_Type__c, &quot;Lodging&quot;),
    ISBLANK(City__c)
)</errorConditionFormula>
    <errorDisplayField>City__c</errorDisplayField>
    <errorMessage>City is required for Lodging expenses.</errorMessage>
</ValidationRule>
