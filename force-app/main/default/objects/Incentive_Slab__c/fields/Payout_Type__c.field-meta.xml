<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Payout_Type__c</fullName>
    <description>Determines how the incentive payout is calculated. Salary Percentage uses the employee gross salary as the base.</description>
    <inlineHelpText>Percentage: payout = Target Value x Slab% x Multiplier. Fixed Amount: payout = Slab Value x Multiplier. Salary Percentage: payout = Employee Gross Salary x Slab% x Multiplier (salary auto-scales for quarterly/annual periods).</inlineHelpText>
    <label>Payout Type</label>
    <required>true</required>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Picklist</type>
    <valueSet>
        <restricted>true</restricted>
        <valueSetDefinition>
            <sorted>false</sorted>
            <value>
                <fullName>Percentage</fullName>
                <default>true</default>
                <label>Percentage</label>
            </value>
            <value>
                <fullName>Fixed Amount</fullName>
                <default>false</default>
                <label>Fixed Amount</label>
            </value>
            <value>
                <fullName>Salary Percentage</fullName>
                <default>false</default>
                <label>Salary Percentage</label>
            </value>
        </valueSetDefinition>
    </valueSet>
</CustomField>
