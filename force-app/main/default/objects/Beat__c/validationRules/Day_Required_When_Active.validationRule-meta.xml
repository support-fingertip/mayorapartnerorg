<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Day_Required_When_Active</fullName>
    <active>true</active>
    <errorConditionFormula>AND(Is_Active__c, ISBLANK(Day_of_Week__c))</errorConditionFormula>
    <errorMessage>Active beats must have at least one day of week assigned.</errorMessage>
</ValidationRule>
