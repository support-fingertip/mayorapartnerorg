<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Territory_Required_When_Active</fullName>
    <active>true</active>
    <errorConditionFormula>AND(Is_Active__c, ISBLANK(Territory__c))</errorConditionFormula>
    <errorMessage>Active beats must be assigned to a territory.</errorMessage>
</ValidationRule>
