<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>From_To_UOM_Different</fullName>
    <active>true</active>
    <description>From UOM and To UOM must be different</description>
    <errorConditionFormula>AND(NOT(ISBLANK(From_UOM__c)), From_UOM__c = To_UOM__c)</errorConditionFormula>
    <errorDisplayField>To_UOM__c</errorDisplayField>
    <errorMessage>From UOM and To UOM must be different.</errorMessage>
</ValidationRule>
