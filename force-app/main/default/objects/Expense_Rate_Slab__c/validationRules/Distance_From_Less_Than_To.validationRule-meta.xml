<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Distance_From_Less_Than_To</fullName>
    <active>true</active>
    <description>Distance From must be less than Distance To when both are specified.</description>
    <errorConditionFormula>AND(
    NOT(ISBLANK(Distance_From__c)),
    NOT(ISBLANK(Distance_To__c)),
    Distance_From__c &gt;= Distance_To__c
)</errorConditionFormula>
    <errorDisplayField>Distance_To__c</errorDisplayField>
    <errorMessage>Distance To must be greater than Distance From.</errorMessage>
</ValidationRule>
